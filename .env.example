# ---- Copy this file to ".env" and fill in real values. Never commit .env. ----

# Server
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:3000

# PostgreSQL (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL=postgres://user:password@localhost:5432/callback_tracker

# ---- Tekmetric API ----
# From your approved Tekmetric API application.
TEKMETRIC_HOST=https://shop.tekmetric.com
TEKMETRIC_CLIENT_ID=your-client-id
TEKMETRIC_CLIENT_SECRET=your-client-secret
# Your shop's numeric ID (returned in the "scope" of the token, and by GET /api/v1/shops).
TEKMETRIC_SHOP_ID=760
# RO statuses to treat as "closed": 5=Posted, 6=Accounts Receivable
TEKMETRIC_RO_STATUSES=5,6
# How far back the ONE-TIME first backfill reaches (npm run sync -- full).
# After that, every nightly run only pulls ROs updated since the last sync.
SYNC_WINDOW_DAYS=30

# ---- Rate-limit safeguards (conservative on purpose) ----
# Max Tekmetric requests per second. 3/sec = 180/min, far under their 600/min.
TEKMETRIC_MAX_RPS=3
# Hard ceiling on total requests in a single sync run. A run that would exceed
# this aborts instead of hammering the API.
TEKMETRIC_MAX_REQUESTS_PER_RUN=1200
# Minimum minutes between syncs (nightly is once/day; this blocks accidental
# re-runs). A full backfill or forced run ignores it. 720 = 12 hours.
SYNC_MIN_INTERVAL_MINUTES=720
# Deep-link pattern for opening an RO in Tekmetric. {shopId} and {roId} are filled in.
# The /estimate view lands the advisor on the list of declined jobs — ideal for a callback.
TEKMETRIC_RO_URL=https://shop.tekmetric.com/admin/shop/{shopId}/repair-orders/{roId}/estimate

# ---- Google sign-in (OAuth / OpenID Connect) ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Anyone with an email at this domain can sign in.
ALLOWED_DOMAIN=precisionauto.com
# The owner (can open the Team & Access admin page). Locked as a manager.
OWNER_EMAIL=owner@precisionauto.com

# Shop's local timezone — used so follow-up due dates line up with "today"
# for your team (not UTC). Examples: America/New_York, America/Chicago,
# America/Denver, America/Los_Angeles.
SHOP_TZ=America/New_York
